# ============================================================================
#  .gitignore — Bhagavad Karma (Angular 21)
#  See https://docs.github.com/get-started/getting-started-with-git/ignoring-files
# ============================================================================

# ── Angular / Build Output ──────────────────────────────────────────────────
/dist/
/tmp/
/out-tsc/
/bazel-out/
/.angular/
/.angular/cache

# ── Dependencies ────────────────────────────────────────────────────────────
/node_modules/

# ── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
*.local

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing / Coverage ──────────────────────────────────────────────────────
/coverage/
/e2e/
testem.log
/typings
__screenshots__/

# ── Tooling output ──────────────────────────────────────────────────────────
graphify-out/
.sass-cache/
/connect.lock
/libpeerconnection.log

# ── IDE / Editor ────────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/*

# VS Code — ignore local settings but KEEP shared team config files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# ── Visual Studio (.NET tooling, if present) ────────────────────────────────
.vs/
bin/
obj/
*.suo
*.user
*.cache

# ── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ============================================================================
#  Do NOT ignore (kept intentionally, listed for reviewer clarity):
#    angular.json, package.json, package-lock.json, .editorconfig,
#    tsconfig*.json, src/assets/, public/ (robots.txt, sitemap.xml, llms.txt)
# ============================================================================
